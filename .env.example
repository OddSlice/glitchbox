# Gemini API key for AI image editing + Style Transfer
# Get yours at https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API key for GPT Image 1.5
# Get yours at https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=your_openai_api_key_here

# SHA-256 hash of the AI access password (gates the AI tab)
# Generate with: echo -n 'your_password' | shasum -a 256
VITE_AI_PASSWORD_HASH=your_sha256_hash_here
